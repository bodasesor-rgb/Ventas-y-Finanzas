# Copia a .env en el servidor (Hostinger) — no subir secretos al repo
PORT=3000

# Ej: https://tudominio.kommo.com
KOMMO_BASE_URL=

# Long-lived access token de Kommo
KOMMO_ACCESS_TOKEN=

# Fase 2: URL de la app web Apps Script (debe terminar en /exec)
# En Hostinger la tienes como URL_BODASESOR_DIRECCION_SHEETS
URL_BODASESOR_DIRECCION_SHEETS=
# Alias opcional:
# APPS_SCRIPT_VENTAS_URL=
# ID_DE_IMPLEMENTACION_BODASESOR_DIRECCION no se usa en el código


